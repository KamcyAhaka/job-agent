# ─── AI ──────────────────────────────────────────────────────
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=

# ─── Firebase ────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings →
# Service Accounts → Generate new private key
# Paste the entire JSON as a single minified line:
# cat service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT=

# ─── Slack ───────────────────────────────────────────────────
# Incoming Webhook:
# api.slack.com/apps → Your App → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=

# Verification Token (for /jobs slash command):
# api.slack.com/apps → Your App → Basic Information → Verification Token
SLACK_VERIFICATION_TOKEN=

# ─── Hunter.io (Optional) ────────────────────────────────────
# Get from: https://hunter.io → Dashboard → API
# Leave empty to skip contact lookup — the agent will still work without it
HUNTER_API_KEY=

GCLOUD_PROJECT=
